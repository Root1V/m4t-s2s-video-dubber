# Copia este archivo como .env y ajusta las rutas a tu entorno.
# El proyecto usa estas variables si las exportas o si usas python-dotenv.
#
#   cp .env.example .env
#   # edita .env con tus rutas
#   export $(cat .env | xargs)   # o usa python-dotenv

# ── Carpetas de trabajo ──────────────────────────────────────────
M4T_INPUT_DIR=/ruta/a/tus/videos
M4T_OUTPUT_DIR=/ruta/a/resultados
M4T_PROCESSED_DIR=/ruta/a/procesados

# ── Modelo ───────────────────────────────────────────────────────
M4T_MODEL_ID=facebook/seamless-m4t-v2-large

# ── Traducción ───────────────────────────────────────────────────
# Idiomas soportados (S2S): eng, spa, fra, deu, por, ita, jpn, cmn, ara, rus, ...
M4T_SRC_LANG=eng          # idioma fuente (el modelo auto-detecta si se omite)
M4T_TGT_LANG=spa          # idioma destino
M4T_SPEAKER_ID=4          # 0-199; usa tools/probar_voces.py para encontrar el mejor

# ── Parámetros de generación ─────────────────────────────────────
M4T_NO_REPEAT_NGRAM_SIZE=5
M4T_REPETITION_PENALTY=1.3
M4T_NUM_BEAMS=2

# ── Límites MPS (Apple Silicon) ──────────────────────────────────
M4T_MAX_CHUNK_S=15        # segundos máx por sub-chunk (MPS INT_MAX limit)
M4T_MIN_CHUNK_S=1         # mínimo para enviar al modelo

# ── VAD ─────────────────────────────────────────────────────────
M4T_VAD_FRAME_MS=20
M4T_VAD_MIN_SILENCE_MS=400
M4T_VAD_PERCENTILE=20
M4T_VAD_MULTIPLIER=3
